# API Configuration
API_KEY=your_api_key
PORT=8000
GENERIC_TIMEZONE=Europe/Madrid

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key

# Database Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=workflowdb
POSTGRES_USER=your_username
POSTGRES_PASSWORD=your_password

# N8N Configuration
N8N_PROTOCOL=http
N8N_HOST=your_host
N8N_PORT=5678
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=your_username
N8N_BASIC_AUTH_PASSWORD=your_password
N8N_USER_MANAGEMENT_DISABLED=true

# Webhook Configuration
WEBHOOK_URL=your_webhook_url

# Opcional: Añadir descripción de cada variable
#
# API_KEY                        - Clave para autenticar peticiones a la API
# GENERIC_TIMEZONE              - Zona horaria por defecto
# OPENAI_API_KEY                - Clave de API para OpenAI
# POSTGRES_*                    - Configuración de la base de datos PostgreSQL
# N8N_*                         - Configuración del servicio n8n
# WEBHOOK_URL                   - URL para webhooks externos